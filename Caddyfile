# ปิด HTTP/3 (บาง firewall บล็อก UDP 443 → บังคับใช้ TCP h1/h2 เสถียรทุกเครือข่าย)
{
    servers {
        protocols h1 h2
    }
}

# แก้ your-domain.com เป็นโดเมนจริง (deploy.sh แทนที่ให้อัตโนมัติ)
your-domain.com {
    encode gzip zstd
    header Cache-Control "no-cache"
    reverse_proxy app:8000
}

# www → รีไดเรกต์ไปโดเมนหลัก
www.your-domain.com {
    redir https://your-domain.com{uri}
}
