{
  "manifest_version": 3,
  "name": "SentinelAI — AI Data Loss Prevention",
  "version": "1.0.0",
  "description": "ดักจับและป้องกันข้อมูลลับองค์กรก่อนถูกส่งไปยัง ChatGPT, Gemini, Claude, Copilot, DeepSeek — ขับเคลื่อนด้วย BytePlus ModelArk",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://sentinelai.help/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://copilot.microsoft.com/*",
    "https://m365.cloud.microsoft/*",
    "https://chat.deepseek.com/*",
    "https://www.perplexity.ai/*",
    "https://grok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SentinelAI",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://copilot.microsoft.com/*",
        "https://m365.cloud.microsoft/*",
        "https://chat.deepseek.com/*",
        "https://www.perplexity.ai/*",
        "https://grok.com/*"
      ],
      "js": ["content/sites.js", "content/overlay.js", "content/interceptor.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
