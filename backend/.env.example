# ============================================================================
# SentinelAI — การตั้งค่า (Configuration)
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง:   cp .env.example .env
# ระบบทำงานได้ 100% แม้ไม่ใส่ ARK_API_KEY (ใช้ชั้น Regex/Fingerprint)
# เมื่อใส่คีย์ BytePlus จะเปิดใช้ "AI Semantic Understanding" อัตโนมัติ
# ============================================================================

# ---- BytePlus ModelArk (OpenAI-compatible) ---------------------------------
# ขอคีย์ได้ที่ console.byteplus.com  → ModelArk → API Keys
ARK_API_KEY=
# Base URL ของภูมิภาค (ค่าเริ่มต้น = ap-southeast / มาเลเซีย)
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# ---- Model IDs (ใช้รุ่นล่าสุด/ดีที่สุด — แก้ให้ตรงกับที่ Activate ในบัญชีได้) -----
# สมองของ Policy Engine (reasoning) — ประเมินบริบทว่าลับจริงไหม
ARK_MODEL_REASONING=seed-2-0-pro-260328
# โมเดลเร็วสำหรับคัดกรองเบา (fast path)
ARK_MODEL_FAST=seed-2-0-lite-260428
# Vision / Document understanding — อ่านภาพหน้าจอ/สลิป/บัตร/PDF
ARK_MODEL_VISION=seed-2-0-pro-260328
# Embedding — ทำ Fingerprint เอกสารลับ + ค้นความคล้ายเชิงความหมาย
ARK_MODEL_EMBEDDING=skylark-embedding-vision-251215

# ---- พฤติกรรมระบบ ----------------------------------------------------------
# โหมดเริ่มต้นทั้งองค์กร (จะถูก override ด้วย Policy รายกฎ): monitor|warn|redact|block
SENTINEL_DEFAULT_MODE=warn
# เรียก AI เฉพาะเมื่อคะแนนเสี่ยงจาก Regex/Fingerprint เกินค่านี้ (คุมต้นทุน/ความหน่วง)
SENTINEL_AI_RISK_THRESHOLD=35
# เก็บเนื้อหาลับฉบับเต็มใน Audit Log หรือไม่ (PDPA: ค่าเริ่มต้น = false = เก็บแค่ metadata)
SENTINEL_STORE_CONTENT=false
# ที่อยู่ไฟล์ฐานข้อมูล sqlite
SENTINEL_DB_PATH=sentinel.db
# ต้นทางที่อนุญาตให้เรียก API (CORS) — extension ใช้ * ได้ผ่าน background fetch
SENTINEL_CORS_ORIGINS=*

# ---- เซิร์ฟเวอร์ -----------------------------------------------------------
SENTINEL_HOST=127.0.0.1
SENTINEL_PORT=8000
