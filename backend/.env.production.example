# ============================================================================
# SentinelAI — ค่าตั้งค่าสำหรับ Production  (คัดลอกเป็น backend/.env แล้วแก้ค่า)
#   cp backend/.env.production.example backend/.env
# ============================================================================

# ---- BytePlus ModelArk (สมอง AI) ----
# ใส่ API key ของคุณ (อย่า commit ไฟล์ .env จริงขึ้น public repo!)
ARK_API_KEY=<<ใส่ ARK_API_KEY ของคุณ>>
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
ARK_MODEL_REASONING=dola-seed-2-1-turbo-260628
ARK_MODEL_FAST=dola-seed-2-1-turbo-260628
ARK_MODEL_VISION=dola-seed-2-1-turbo-260628
ARK_MODEL_EMBEDDING=skylark-embedding-vision-251215

# ---- ความปลอดภัยของแพลตฟอร์ม (สำคัญมากสำหรับ production!) ----
# สร้างคีย์สุ่มยาว ๆ:  python -c "import secrets;print(secrets.token_urlsafe(48))"
SENTINEL_JWT_SECRET=<<ใส่คีย์สุ่มที่สร้างเอง — ห้ามใช้ค่าตัวอย่าง>>

# อีเมล Super Admin (เจ้าของแพลตฟอร์ม) — คั่นด้วย , ได้หลายคน
SENTINEL_ADMIN_EMAILS=you@yourcompany.com

# ---- License / การจำกัดสิทธิ์ ----
SENTINEL_ENFORCE_LICENSE=true       # true = บล็อก key ที่ไม่ได้ซื้อ/หมดสิทธิ์
SENTINEL_TRIAL_DAYS=14              # ทดลองใช้ฟรีกี่วัน

# ---- พฤติกรรมระบบ ----
SENTINEL_DEFAULT_MODE=warn
SENTINEL_AI_RISK_THRESHOLD=35
SENTINEL_STORE_CONTENT=false
SENTINEL_DB_PATH=/data/sentinel.db  # อยู่บนโวลุ่มถาวร (compose)

# ---- CORS ----
# extension เรียกข้ามโดเมน — * ใช้ได้ (ไม่ส่ง credentials)
SENTINEL_CORS_ORIGINS=*
